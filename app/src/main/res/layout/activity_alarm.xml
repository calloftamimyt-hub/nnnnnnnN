<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">
    <TextView android:id="@+id/alarmTimeText" android:layout_width="wrap_content" android:layout_height="wrap_content" />
    <TextView android:id="@+id/alarmLabelText" android:layout_width="wrap_content" android:layout_height="wrap_content" />
    <Button android:id="@+id/snoozeButton" android:layout_width="wrap_content" android:layout_height="wrap_content" />
    <Button android:id="@+id/dismissButton" android:layout_width="wrap_content" android:layout_height="wrap_content" />
</LinearLayout>
